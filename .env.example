# ── MySQL ────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=changeme

# ── MinIO (S3 대체) ───────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# ── 공통 (backend + worker 공유) ─────────────────────────
KAFKA_BOOTSTRAP_SERVERS=kafka:9092

AWS_ACCESS_KEY_ID=minioadmin          # MinIO user와 동일하게
AWS_SECRET_ACCESS_KEY=minioadmin      # MinIO password와 동일하게
S3_BUCKET=ai-ready-platform
S3_ENDPOINT_URL=http://minio:9000     # 로컬 MinIO. Railway 배포 시 교체

# ── Backend (Spring Boot) ────────────────────────────────
SPRING_DATASOURCE_URL=jdbc:mysql://mysql:3306/aiready
SPRING_DATASOURCE_PASSWORD=changeme   # MYSQL_ROOT_PASSWORD와 동일하게

# ── Worker (FastAPI) ─────────────────────────────────────
MYSQL_URL=mysql+asyncmy://root:changeme@mysql:3306/aiready
OPENAI_API_KEY=sk-...
