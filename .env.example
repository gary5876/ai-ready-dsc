# ── MySQL ────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=changeme

# ── MinIO (S3 대체) ───────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# ── 공통 (backend + worker 공유) ─────────────────────────
KAFKA_BOOTSTRAP_SERVERS=kafka:9092

# [로컬] MinIO
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET=ai-ready-platform
S3_ENDPOINT_URL=http://minio:9000

# [Railway] 위 4개를 아래 값으로 교체 (MinIO 불필요)
# AWS_ACCESS_KEY_ID=<Railway Credentials에서 복사>
# AWS_SECRET_ACCESS_KEY=<Railway Credentials에서 복사>
# S3_BUCKET=stocked-carrier-zbp2l7j5u
# S3_ENDPOINT_URL=https://t3.storageapi.dev
# AWS_REGION=auto

# ── Backend (Spring Boot) ────────────────────────────────
SPRING_DATASOURCE_URL=jdbc:mysql://mysql:3306/aiready
SPRING_DATASOURCE_PASSWORD=changeme   # MYSQL_ROOT_PASSWORD와 동일하게

# ── Worker (FastAPI) ─────────────────────────────────────
MYSQL_URL=mysql+asyncmy://root:changeme@mysql:3306/aiready
OPENAI_API_KEY=sk-...
