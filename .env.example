# ============================================================
#  로컬 (docker-compose)
# ============================================================

# ── MySQL ────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=changeme

# ── Kafka ────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=kafka:9092

# ── S3 (Railway Object Storage) ──────────────────────────
AWS_ACCESS_KEY_ID=<Railway Credentials에서 복사>
AWS_SECRET_ACCESS_KEY=<Railway Credentials에서 복사>
S3_BUCKET=stocked-carrier-zbp2l7j5u
S3_ENDPOINT_URL=https://t3.storageapi.dev

# ── Backend ──────────────────────────────────────────────
SPRING_DATASOURCE_URL=jdbc:mysql://mysql:3306/aiready
SPRING_DATASOURCE_PASSWORD=changeme

# ── Worker ───────────────────────────────────────────────
MYSQL_URL=mysql+asyncmy://root:changeme@mysql:3306/aiready
OPENAI_API_KEY=sk-...

# ── Frontend ─────────────────────────────────────────────
BACKEND_URL=http://backend:8080


# ============================================================
#  Railway (서비스별 Variables 탭에 입력)
# ============================================================

# ── zookeeper 서비스 ──────────────────────────────────────
# ZOOKEEPER_CLIENT_PORT=2181
# ZOOKEEPER_TICK_TIME=2000

# ── kafka 서비스 ──────────────────────────────────────────
# ZOOKEEPER_HOST=zookeeper.railway.internal
# KAFKA_BROKER_ID=1
# KAFKA_ZOOKEEPER_CONNECT=zookeeper.railway.internal:2181
# KAFKA_ADVERTISED_LISTENERS=PLAINTEXT://kafka.railway.internal:9092
# KAFKA_LISTENERS=PLAINTEXT://0.0.0.0:9092
# KAFKA_AUTO_CREATE_TOPICS_ENABLE=true
# KAFKA_NUM_PARTITIONS=4
# KAFKA_OFFSETS_TOPIC_REPLICATION_FACTOR=1

# ── backend 서비스 ────────────────────────────────────────
# KAFKA_BOOTSTRAP_SERVERS=kafka.railway.internal:9092
# SPRING_DATASOURCE_URL=jdbc:mysql://<Railway MySQL 호스트>/aiready
# SPRING_DATASOURCE_PASSWORD=<Railway MySQL 비밀번호>
# AWS_ACCESS_KEY_ID=<Railway Credentials>
# AWS_SECRET_ACCESS_KEY=<Railway Credentials>
# S3_BUCKET=stocked-carrier-zbp2l7j5u
# S3_ENDPOINT_URL=https://t3.storageapi.dev

# ── worker 서비스 ─────────────────────────────────────────
# KAFKA_BOOTSTRAP_SERVERS=kafka.railway.internal:9092
# MYSQL_URL=mysql+asyncmy://root:<pw>@<Railway MySQL 호스트>/aiready
# OPENAI_API_KEY=sk-...
# AWS_ACCESS_KEY_ID=<Railway Credentials>
# AWS_SECRET_ACCESS_KEY=<Railway Credentials>
# S3_BUCKET=stocked-carrier-zbp2l7j5u
# S3_ENDPOINT_URL=https://t3.storageapi.dev

# ── frontend 서비스 ───────────────────────────────────────
# BACKEND_URL=http://backend.railway.internal:8080
